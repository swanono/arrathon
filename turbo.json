{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "type:check": {
      "cache": true,
      "outputs": [],
      "dependsOn": ["build"]
    },
    "lint:check": {
      "cache": true,
      "outputs": [],
      "dependsOn": []
    },
    "format:check": {
      "cache": true,
      "outputs": [],
      "dependsOn": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
